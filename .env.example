# 服务端口
PORT=8080

# MariaDB 数据库连接
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ofo
DB_PASSWORD=your_password
DB_NAME=ofo

# 博客标题
BLOG_TITLE=骑自行车

# 作者名
BLOG_AUTHOR=青头儿包

# 对外访问的完整 URL（上线时改为真实域名）
BASE_URL=https://www.yourdomain.com

# 是否写入示例数据（首次设为 true，后续可改为 false）
SEED_DB=true

# 静态资源版本号（更新 CSS/JS 后递增，强制浏览器刷新缓存）
ASSET_VERSION=1

# 管理员登录密码（务必修改）
ADMIN_PASSWORD=admin123

# ---- SEO 配置 ----
# 全站默认关键词（逗号分隔）
BLOG_KEYWORDS=搞笑图片,趣味短片,奇闻趣事,资源分享

# 百度站点验证码（在百度搜索资源平台获取）
BAIDU_VERIFY=

# 360站点验证码
VERIFY_360=

# 搜狗站点验证码
SOGOU_VERIFY=

# ---- 反盗链 / 反爬虫 ----
# 是否启用 Referer 防盗链（true=开启，false=关闭）
HOTLINK_PROTECTION=true

# 额外允许的 Referer 域名（逗号分隔，用于允许特定外部站点引用资源）
# 搜索引擎（Google/Bing/Baidu 等）已内置放行，无需在此添加
ALLOWED_REFERRERS=

# 静态资源（图片/视频）每 IP 每秒最大请求数（0=不限制）
STATIC_RATE_LIMIT=20

# ---- 存储后端 ----
# 可选值：local（本地磁盘）| qiniu（七牛云 Kodo）
STORAGE_BACKEND=local

# 七牛云配置（仅 STORAGE_BACKEND=qiniu 时需要）
# 在 https://portal.qiniu.com/user/key 获取 AccessKey / SecretKey
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
# 存储空间名称
QINIU_BUCKET=
# CDN 加速域名（含协议），如 https://cdn.example.com
QINIU_DOMAIN=
