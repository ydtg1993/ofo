# 服务端口
PORT=8080

# MariaDB 数据库连接
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ofo
DB_PASSWORD=your_password
DB_NAME=ofo

# 博客标题
BLOG_TITLE=骑自行车

# 作者名
BLOG_AUTHOR=青头儿包

# 对外访问的完整 URL（上线时改为真实域名）
BASE_URL=https://www.yourdomain.com

# 是否写入示例数据（首次设为 true，后续可改为 false）
SEED_DB=true

# 静态资源版本号（更新 CSS/JS 后递增，强制浏览器刷新缓存）
ASSET_VERSION=1

# 管理员登录密码（务必修改）
ADMIN_PASSWORD=admin123

# ---- SEO 配置 ----
# 全站默认关键词（逗号分隔）
BLOG_KEYWORDS=搞笑图片,趣味短片,奇闻趣事,资源分享

# 百度站点验证码（在百度搜索资源平台获取）
BAIDU_VERIFY=

# 360站点验证码
VERIFY_360=

# 搜狗站点验证码
SOGOU_VERIFY=
