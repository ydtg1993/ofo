# ofo 项目配置文件
# 复制此文件为 .env，按需修改后加载
#
# 优先级：系统环境变量 > .env > 代码默认值
# 即 .env 里的值不会覆盖系统环境变量中已设置的同名变量

# 服务端口
PORT=8080

# MariaDB 数据库连接
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ofo
SEED_DB=true

# 博客标题
BLOG_TITLE=骑自行车

# 作者名
BLOG_AUTHOR=青头儿包

# 对外访问的完整 URL（上线时改为真实域名）
BASE_URL=http://localhost:8080

# 是否写入示例数据（首次启动设为 true，后续可改为 false 跳过）
SEED_DB=true

# 管理员登录密码（务必修改）
ADMIN_PASSWORD=admin123

# ---- SEO 配置 ----
# 全站默认关键词（逗号分隔）
BLOG_KEYWORDS=搞笑图片,趣味短片,奇闻趣事,搞笑视频

# 百度站点验证码（在百度搜索资源平台获取）
BAIDU_VERIFY=

# 360站点验证码
VERIFY_360=

# 搜狗站点验证码
SOGOU_VERIFY=
